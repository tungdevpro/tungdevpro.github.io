---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";
import Card from "@components/Card";
import Socials from "@components/Socials.astro";
import getSortedPosts from "@utils/getSortedPosts";
import { SOCIALS, SITE } from "@config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const socialCount = SOCIALS.filter((social) => social.active).length;
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <div class="hero-copy">
        <p class="eyebrow">Mobile engineering notes</p>
        <h1>{SITE.title}</h1>
        <p class="intro">{SITE.quickIntroduceMySelf}</p>
        <p class="fact">{SITE.fact}</p>
      </div>
      {
        // only display if at least one social link is enabled
        socialCount > 0 && (
          <div class="social-wrapper">
            <div class="social-links">Find me on</div>
            <Socials />
          </div>
        )
      }
    </section>

    <Hr />

    {
      featuredPosts.length > 0 && (
        <>
          <section id="featured">
            <div class="section-heading">
              <h2>Featured Posts</h2>
              <p>Selected writing from the archive.</p>
            </div>
            <ul>
              {featuredPosts.map(({ data, slug }) => (
                <Card
                  href={`/posts/${slug}/`}
                  frontmatter={data}
                  secHeading={false}
                />
              ))}
            </ul>
          </section>
          {recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts">
          <div class="section-heading">
            <h2>Recent Posts</h2>
            <p>Latest notes and engineering write-ups.</p>
          </div>
          <ul>
            {recentPosts.map(
              ({ data, slug }, index) =>
                index < 4 && (
                  <Card
                    href={`/posts/${slug}/`}
                    frontmatter={data}
                    secHeading={false}
                  />
                ),
            )}
          </ul>
        </section>
      )
    }

    <div class="all-posts-btn-wrapper">
      <LinkButton href="/posts/" className="all-posts-btn focus-outline">
        All Posts
        <svg xmlns="http://www.w3.org/2000/svg"
          ><path
            d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z"
          ></path>
        </svg>
      </LinkButton>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* ===== Hero Section ===== */
  #hero {
    @apply grid gap-6 pb-10 pt-10 sm:grid-cols-[1fr_auto] sm:items-end sm:pt-16;
  }
  .hero-copy {
    @apply max-w-3xl;
  }
  .eyebrow {
    @apply mb-3 text-sm font-semibold uppercase tracking-[0.12em] text-skin-accent;
  }
  #hero h1 {
    @apply text-4xl font-semibold leading-tight tracking-normal sm:text-6xl;
  }
  .intro {
    @apply mt-5 max-w-2xl text-lg leading-8 opacity-85;
  }
  .fact {
    @apply mt-4 text-sm opacity-65;
  }
  .social-wrapper {
    @apply flex flex-col gap-2 rounded-lg border border-skin-line bg-skin-card p-4 shadow-sm sm:min-w-44;
  }
  .social-links {
    @apply whitespace-nowrap text-sm font-medium opacity-70;
  }

  /* ===== Featured & Recent Posts Sections ===== */
  #featured,
  #recent-posts {
    @apply pb-6 pt-10;
  }
  .section-heading {
    @apply mb-5;
  }
  .section-heading h2 {
    @apply text-2xl font-semibold tracking-normal;
  }
  .section-heading p {
    @apply mt-1 text-sm opacity-70;
  }
  .all-posts-btn-wrapper {
    @apply my-8 text-center;
  }
  .all-posts-btn {
    @apply min-h-11 rounded-md bg-skin-inverted px-5 py-2.5 font-medium text-skin-inverted transition duration-200 hover:bg-skin-accent hover:text-skin-inverted;
  }
</style>
